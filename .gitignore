# Ignore MySQL runtime and local data
mysql_data/
*.pid
*.err
*.out
*.log

# Ignore Tomcat runtime and temporary files
tomcat9/apache-tomcat-9.0.99/work/
tomcat9/apache-tomcat-9.0.99/temp/
